@{
    ViewData["Title"] = "Entry";

    var activeContext = (ViewData["ActiveContext"] as string ?? "company").ToLowerInvariant();
    var defaultSlug = ViewData["DefaultSlug"] as string;
}

<section class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <h1 class="h4 mb-3">Entry</h1>
        <p class="text-muted mb-4">
            Your session is active. Continue with the context needed for onboarding and authentication continuity during UI rework.
        </p>

        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary" asp-controller="Landing" asp-action="Entry" asp-route-context="company">Company context</a>
            <a class="btn btn-outline-primary" asp-controller="Landing" asp-action="Entry" asp-route-context="customer">Customer context</a>
            <a class="btn btn-outline-secondary" asp-controller="Landing" asp-action="Index">Back to landing</a>
        </div>

        <div class="mt-3 text-muted small">
            <div>Active context: <strong>@activeContext</strong></div>
            @if (!string.IsNullOrWhiteSpace(defaultSlug))
            {
                <div>Resolved slug: <strong>@defaultSlug</strong></div>
            }
        </div>
    </div>
</section>
