@model WebApp.ViewModels.Landing.ExistingUserTenantSignupViewModel
@{
    ViewData["Title"] = "Register New Company";
}

<div class="landing-page">
    <section class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <h2 class="h4 mb-3">Register New Company</h2>

            @if (TempData["SuccessMessage"] is string successMessage)
            {
                <div class="alert alert-success" role="alert">@successMessage</div>
            }

            <form asp-controller="Landing" asp-action="SignupAuthenticated" method="post" novalidate>
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="CompanyName" class="form-label"></label>
                        <input asp-for="CompanyName" class="form-control" />
                        <span asp-validation-for="CompanyName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="RegistrationNumber" class="form-label"></label>
                        <input asp-for="RegistrationNumber" class="form-control" />
                        <span asp-validation-for="RegistrationNumber" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="CompanyContactEmail" class="form-label"></label>
                        <input asp-for="CompanyContactEmail" class="form-control" />
                        <span asp-validation-for="CompanyContactEmail" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="CompanyContactPhone" class="form-label"></label>
                        <input asp-for="CompanyContactPhone" class="form-control" />
                        <span asp-validation-for="CompanyContactPhone" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="CompanyWebsiteUrl" class="form-label"></label>
                        <input asp-for="CompanyWebsiteUrl" class="form-control" />
                        <span asp-validation-for="CompanyWebsiteUrl" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-success">Create company</button>
                    <a asp-controller="Landing" asp-action="Entry" asp-route-context="company" class="btn btn-outline-secondary">Back</a>
                </div>
            </form>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
