@model App.Domain.Support.TenantSupportAccess

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>TenantSupportAccess</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="CompanyId" class="control-label"></label>
                <select asp-for="CompanyId" class ="form-control" asp-items="ViewBag.CompanyId"></select>
            </div>
            <div class="form-group">
                <label asp-for="SupportUserId" class="control-label"></label>
                <select asp-for="SupportUserId" class ="form-control" asp-items="ViewBag.SupportUserId"></select>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="IsReadOnly" /> @Html.DisplayNameFor(model => model.IsReadOnly)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="Reason" class="control-label"></label>
                <input asp-for="Reason" class="form-control" />
                <span asp-validation-for="Reason" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="GrantedAt" class="control-label"></label>
                <input asp-for="GrantedAt" class="form-control" />
                <span asp-validation-for="GrantedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="RevokedAt" class="control-label"></label>
                <input asp-for="RevokedAt" class="form-control" />
                <span asp-validation-for="RevokedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="GrantedByAppUserId" class="control-label"></label>
                <select asp-for="GrantedByAppUserId" class ="form-control" asp-items="ViewBag.GrantedByAppUserId"></select>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
