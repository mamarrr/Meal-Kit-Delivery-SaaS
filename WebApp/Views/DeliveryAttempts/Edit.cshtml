@model WebApp.ViewModels.DeliveryAttempts.DeliveryAttemptEditViewModel

@{
    ViewData["Title"] = "Edit Delivery Attempt";
}

<h1>Edit Delivery Attempt</h1>

<h4>Update attempt details</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="DeliveryAttempt.Id" />
            <div class="form-group">
                <label asp-for="DeliveryAttempt.DeliveryId" class="control-label"></label>
                <select asp-for="DeliveryAttempt.DeliveryId" class="form-control" asp-items="Model.DeliveryOptions"></select>
                <span asp-validation-for="DeliveryAttempt.DeliveryId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DeliveryAttempt.AttemptNo" class="control-label"></label>
                <input asp-for="DeliveryAttempt.AttemptNo" class="form-control" />
                <span asp-validation-for="DeliveryAttempt.AttemptNo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DeliveryAttempt.AttemptAt" class="control-label"></label>
                <input asp-for="DeliveryAttempt.AttemptAt" class="form-control" type="datetime-local" />
                <span asp-validation-for="DeliveryAttempt.AttemptAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DeliveryAttempt.DeliveryAttemptResultId" class="control-label"></label>
                <select asp-for="DeliveryAttempt.DeliveryAttemptResultId" class="form-control" asp-items="Model.DeliveryAttemptResultOptions"></select>
                <span asp-validation-for="DeliveryAttempt.DeliveryAttemptResultId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DeliveryAttempt.Notes" class="control-label"></label>
                <textarea asp-for="DeliveryAttempt.Notes" class="form-control" rows="3"></textarea>
                <span asp-validation-for="DeliveryAttempt.Notes" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
