@model WebApp.ViewModels.BoxPrices.BoxPriceEditViewModel

@{
    ViewData["Title"] = "Create Box Price";
}

<h1>Create Box Price</h1>

<h4>Box Price</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="BoxPrice.BoxId" class="control-label"></label>
                <select asp-for="BoxPrice.BoxId" class="form-control" asp-items="Model.BoxOptions">
                    <option value="">-- Select Box --</option>
                </select>
                <span asp-validation-for="BoxPrice.BoxId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BoxPrice.PriceAmount" class="control-label"></label>
                <input asp-for="BoxPrice.PriceAmount" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="BoxPrice.PriceAmount" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BoxPrice.ValidFrom" class="control-label"></label>
                <input asp-for="BoxPrice.ValidFrom" class="form-control" type="datetime-local" />
                <span asp-validation-for="BoxPrice.ValidFrom" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BoxPrice.ValidTo" class="control-label"></label>
                <input asp-for="BoxPrice.ValidTo" class="form-control" type="datetime-local" />
                <span asp-validation-for="BoxPrice.ValidTo" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="BoxPrice.IsActive" /> @Html.DisplayNameFor(model => model.BoxPrice.IsActive)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
