@using System.Threading
@using WebApp.Helpers
@inject AppNameService AppNameService;
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Robot</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/WebApp.styles.css" asp-append-version="true"/>
    @await RenderSectionAsync("HeaderScripts", required: false)
</head>
<body>
<a class="skip-link" href="#main-content">Skip to main content</a>
<header class="site-header">
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm mb-4" aria-label="Global navigation">
        <div class="container">
            <a class="navbar-brand fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">@AppNameService.AppName</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                    aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse justify-content-between">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 align-items-lg-center gap-lg-1">
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">@App.Resources.Views.Shared._Layout.Home</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Customer View
                        </a>
                        <ul class="dropdown-menu">
                            <li><span class="dropdown-item-text small text-muted">Workflow pages planned in this change</span></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Company View
                        </a>
                        <ul class="dropdown-menu">
                            <li><span class="dropdown-item-text small text-muted">Workflow pages planned in this change</span></li>
                        </ul>
                    </li>
                    @if (User.IsInRole("root"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                Root
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-area="Root" asp-controller="Users" asp-action="Index">Users</a>
                                </li>
                            </ul>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav align-items-lg-center gap-lg-1">
                    <partial name="_LanguageSelection"/>
                    <partial name="_LoginPartial"/>
                </ul>
            </div>
        </div>
    </nav>
</header>
<div class="container pb-4">
    <main id="main-content" role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted py-3 mt-auto">
    <div class="container">
        @AppNameService.AppName - <a asp-area="" asp-controller="Home" asp-action="Privacy">@App.Resources.Views.Shared._Layout.Privacy</a> | 
        <a href="/swagger">Api</a> | 
        @Thread.CurrentThread.CurrentCulture.Name
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/lib/htmx.org/dist/htmx.min.js"></script>
<script src="~/lib/alpinejs/dist/cdn.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
