@using System.Threading
@using WebApp.Helpers
@inject AppNameService AppNameService;
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Robot</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/WebApp.styles.css" asp-append-version="true"/>
    @await RenderSectionAsync("HeaderScripts", required: false)
</head>
<body>
<a class="skip-link" href="#main-content">Skip to main content</a>
<header class="site-header">
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm mb-4" aria-label="Global navigation">
        <div class="container">
            <a class="navbar-brand fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">@AppNameService.AppName</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                    aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse justify-content-between">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 align-items-lg-center gap-lg-1">
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">@App.Resources.Views.Shared._Layout.Home</a>
                    </li>
                    @if (User.IsInRole("Customer"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Customer View
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="MealPlans" asp-action="Index">Discover Plans</a></li>
                                <li><a class="dropdown-item" asp-controller="MealSubscriptions" asp-action="Index">My Subscriptions</a></li>
                                <li><a class="dropdown-item" asp-controller="CustomerPreferences" asp-action="Index">Dietary Preferences</a></li>
                                <li><a class="dropdown-item" asp-controller="CustomerExclusions" asp-action="Index">Ingredient Exclusions</a></li>
                                <li><a class="dropdown-item" asp-controller="WeeklyMenus" asp-action="Index">Weekly Menus</a></li>
                                <li><a class="dropdown-item" asp-controller="MealSelections" asp-action="Index">Meal Selections</a></li>
                                <li><a class="dropdown-item" asp-controller="Deliveries" asp-action="Index">My Deliveries</a></li>
                                <li><a class="dropdown-item" asp-controller="QualityComplaints" asp-action="Index">Quality Complaints</a></li>
                            </ul>
                        </li>
                    }
                    @if (User.IsInRole("CompanyOwner") || User.IsInRole("CompanyAdmin") || User.IsInRole("CompanyManager") || User.IsInRole("CompanyEmployee"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Company View
                            </a>
                             <ul class="dropdown-menu">
                                 <li><a class="dropdown-item" asp-controller="CompanySettings" asp-action="Profile">Company Profile</a></li>
                                 <li><a class="dropdown-item" asp-controller="CompanySettings" asp-action="Index">Operational Settings</a></li>
                                 <li><a class="dropdown-item" asp-controller="Boxes" asp-action="Index">Box Sizes</a></li>
                                 <li><a class="dropdown-item" asp-controller="BoxPrices" asp-action="Index">Pricing</a></li>
                                 <li><a class="dropdown-item" asp-controller="DietaryCategories" asp-action="Index">Dietary Categories</a></li>
                                 <li><a class="dropdown-item" asp-controller="Recipes" asp-action="Index">Recipe Pool</a></li>
                                 <li><a class="dropdown-item" asp-controller="WeeklyMenus" asp-action="Index">Weekly Menus</a></li>
                                 <li><a class="dropdown-item" asp-controller="WeeklyMenus" asp-action="Deadlines">Selection Deadlines</a></li>
                                 <li><a class="dropdown-item" asp-controller="DeliveryZones" asp-action="Index">Delivery Zones</a></li>
                                <li><a class="dropdown-item" asp-controller="DeliveryWindows" asp-action="Index">Delivery Windows</a></li>
                                <li><a class="dropdown-item" asp-controller="Deliveries" asp-action="Index">Delivery Tracking</a></li>
                                <li><a class="dropdown-item" asp-controller="QualityComplaints" asp-action="Index">Complaints</a></li>
                                <li><a class="dropdown-item" asp-controller="CompanyUsers" asp-action="Index">Users &amp; Roles</a></li>
                                <li><a class="dropdown-item" asp-controller="PlatformSubscriptions" asp-action="Index">Subscription</a></li>
                            </ul>
                        </li>
                    }
                    @if (User.IsInRole("SystemAdmin") || User.IsInRole("SystemBilling") || User.IsInRole("SystemSupport"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                System
                            </a>
                            <ul class="dropdown-menu">
                                @if (User.IsInRole("SystemAdmin"))
                                {
                                    <li><a class="dropdown-item" asp-controller="Companies" asp-action="Index">Companies</a></li>
                                    <li><a class="dropdown-item" asp-controller="SystemSettings" asp-action="Index">System Settings</a></li>
                                    <li><a class="dropdown-item" asp-controller="Analytics" asp-action="Index">Analytics</a></li>
                                    <li><a class="dropdown-item" asp-controller="SupportImpersonation" asp-action="Index">Impersonation</a></li>
                                }
                                 @if (User.IsInRole("SystemAdmin") || User.IsInRole("SystemBilling"))
                                 {
                                     <li><a class="dropdown-item" asp-controller="PlatformSubscriptionTiers" asp-action="Index">Subscription Plans</a></li>
                                     <li><a class="dropdown-item" asp-controller="Invoices" asp-action="Index">Billing &amp; Invoices</a></li>
                                 }
                                @if (User.IsInRole("SystemAdmin") || User.IsInRole("SystemSupport"))
                                {
                                    <li><a class="dropdown-item" asp-controller="SupportTickets" asp-action="Index">Support Tickets</a></li>
                                    <li><a class="dropdown-item" asp-controller="SupportAccess" asp-action="Index">Support Access</a></li>
                                }
                            </ul>
                        </li>
                    }
                    @if (User.IsInRole("root"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                Root
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-area="Root" asp-controller="Users" asp-action="Index">Users</a>
                                </li>
                            </ul>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav align-items-lg-center gap-lg-1">
                    <partial name="_LanguageSelection"/>
                    <partial name="_LoginPartial"/>
                </ul>
            </div>
        </div>
    </nav>
</header>
<div class="container pb-4">
    <main id="main-content" role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted py-3 mt-auto">
    <div class="container">
        @AppNameService.AppName - <a asp-area="" asp-controller="Home" asp-action="Privacy">@App.Resources.Views.Shared._Layout.Privacy</a> | 
        <a href="/swagger">Api</a> | 
        @Thread.CurrentThread.CurrentCulture.Name
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/lib/htmx.org/dist/htmx.min.js"></script>
<script src="~/lib/alpinejs/dist/cdn.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
