@using System.Threading
@using WebApp.ViewModels.Shared
@using WebApp.Helpers
@inject AppNameService AppNameService;
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - @AppNameService.AppName</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/WebApp.styles.css" asp-append-version="true"/>
    @await RenderSectionAsync("HeaderScripts", required: false)
</head>
<body>
<a class="skip-link" href="#main-content">Skip to main content</a>
@if (User.Identity?.IsAuthenticated == true)
{
    var operationalSlug = User.GetCompanySlug();
    var activeContext = Context.Request.Cookies[ActiveUserSelectionHelper.ActiveContextCookieName]?.ToLowerInvariant();
    var hasCustomerAccess = User.IsInRole("Customer") || User.HasClaim("has_customer_access", "true");
    var hasCompanyAccess = User.IsInRole("CompanyOwner") || User.IsInRole("CompanyAdmin") || User.IsInRole("CompanyManager") || User.IsInRole("CompanyEmployee") || User.HasClaim("has_company_access", "true") || !string.IsNullOrWhiteSpace(operationalSlug);
    var canRegisterNewCompany = ActiveUserSelectionHelper.CanRegisterNewCompanyFromSidebar(User);

    if (string.IsNullOrWhiteSpace(activeContext))
    {
        activeContext = hasCompanyAccess ? ActiveUserSelectionHelper.CompanyContext : (hasCustomerAccess ? ActiveUserSelectionHelper.CustomerContext : ActiveUserSelectionHelper.SystemContext);
    }

    var sidebarItems = new List<AppShellNavigationViewModel>
    {
        new() { Title = "Entry", Controller = "Landing", Action = "Entry", Slug = activeContext == "company" ? operationalSlug : null }
    };

    if (canRegisterNewCompany)
    {
        sidebarItems.Add(new AppShellNavigationViewModel
        {
            Title = "Register new company",
            Controller = "Landing",
            Action = "CompanySignupAuthenticated",
            Context = "company-register"
        });
    }

<div class="app-shell">
    <partial name="_SidebarNavigation" model="sidebarItems" />

    <div class="app-main">
        <header class="app-topbar">
            <div class="app-topbar-brand">
                <a class="navbar-brand fw-semibold" asp-area="" asp-controller="Landing" asp-action="Index">@AppNameService.AppName</a>
            </div>
            <div class="app-topbar-actions">
                <ul class="navbar-nav">
                    <partial name="_LoginPartial" />
                </ul>
            </div>
        </header>

        <main id="main-content" role="main" class="app-content">
            @RenderBody()
        </main>
    </div>
</div>
}
else
{
    <div class="container py-4">
        <header class="d-flex justify-content-between align-items-center mb-3">
            <a class="navbar-brand fw-semibold" asp-area="" asp-controller="Landing" asp-action="Index">@AppNameService.AppName</a>
            <ul class="navbar-nav flex-row gap-3">
                <partial name="_LoginPartial" />
            </ul>
        </header>

        <main id="main-content" role="main" class="app-content">
            @RenderBody()
        </main>
    </div>
}

<footer class="border-top footer text-muted py-3 mt-auto">
    <div class="container">
        @AppNameService.AppName - <a asp-area="" asp-controller="Home" asp-action="Privacy">@App.Resources.Views.Shared._Layout.Privacy</a> | 
        <a href="/swagger">Api</a>
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/lib/htmx.org/dist/htmx.min.js"></script>
<script src="~/lib/alpinejs/dist/cdn.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
