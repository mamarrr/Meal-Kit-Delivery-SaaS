@using System.Threading
@using WebApp.ViewModels.Shared
@using WebApp.Helpers
@inject AppNameService AppNameService;
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - @AppNameService.AppName</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/WebApp.styles.css" asp-append-version="true"/>
    @await RenderSectionAsync("HeaderScripts", required: false)
</head>
<body>
<a class="skip-link" href="#main-content">Skip to main content</a>
@{
    var operationalSlug = User.GetDefaultOperationalSlug();

    var sidebarItems = new List<AppShellNavigationViewModel>
    {
        new() { Title = "Home", Controller = "Landing", Action = "Entry", Slug = operationalSlug }
    };

    if (User.IsInRole("Customer"))
    {
        sidebarItems.AddRange(
        new List<AppShellNavigationViewModel>
        {
            new() { Title = "Discover Plans", Controller = "MealPlans", Action = "Index" },
            new() { Title = "My Subscriptions", Controller = "MealSubscriptions", Action = "Index" },
            new() { Title = "Dietary Preferences", Controller = "CustomerPreferences", Action = "Index" },
            new() { Title = "Ingredient Exclusions", Controller = "CustomerExclusions", Action = "Index" },
            new() { Title = "Weekly Menus", Controller = "WeeklyMenus", Action = "Index" },
            new() { Title = "Meal Selections", Controller = "MealSelections", Action = "Index" },
            new() { Title = "My Deliveries", Controller = "Deliveries", Action = "Index" },
            new() { Title = "Quality Complaints", Controller = "QualityComplaints", Action = "Index" }
        }.Select(x =>
        {
            x.Slug = operationalSlug;
            return x;
        }));
    }

    if (User.IsInRole("CompanyOwner") || User.IsInRole("CompanyAdmin") || User.IsInRole("CompanyManager") || User.IsInRole("CompanyEmployee"))
    {
        sidebarItems.AddRange(
        new List<AppShellNavigationViewModel>
        {
            new() { Title = "Company Profile", Controller = "CompanySettings", Action = "Profile" },
            new() { Title = "Operational Settings", Controller = "CompanySettings", Action = "Index" },
            new() { Title = "Box Sizes", Controller = "Boxes", Action = "Index" },
            new() { Title = "Pricing", Controller = "BoxPrices", Action = "Index" },
            new() { Title = "Dietary Categories", Controller = "DietaryCategories", Action = "Index" },
            new() { Title = "Recipe Pool", Controller = "Recipes", Action = "Index" },
            new() { Title = "Weekly Menus", Controller = "WeeklyMenus", Action = "Index" },
            new() { Title = "Selection Deadlines", Controller = "WeeklyMenus", Action = "Deadlines" },
            new() { Title = "Delivery Zones", Controller = "DeliveryZones", Action = "Index" },
            new() { Title = "Delivery Windows", Controller = "DeliveryWindows", Action = "Index" },
            new() { Title = "Delivery Tracking", Controller = "Deliveries", Action = "Index" },
            new() { Title = "Complaints", Controller = "QualityComplaints", Action = "Index" },
            new() { Title = "Users & Roles", Controller = "CompanyUsers", Action = "Index" },
            new() { Title = "Subscription", Controller = "PlatformSubscriptions", Action = "Index" }
        }.Select(x =>
        {
            x.Slug = operationalSlug;
            return x;
        }));
    }

    if (User.IsInRole("SystemAdmin") || User.IsInRole("SystemBilling") || User.IsInRole("SystemSupport"))
    {
        sidebarItems.AddRange(
        new List<AppShellNavigationViewModel>
        {
            new() { Title = "Companies", Controller = "Companies", Action = "Index" },
            new() { Title = "System Settings", Controller = "SystemSettings", Action = "Index" },
            new() { Title = "Analytics", Controller = "Analytics", Action = "Index" },
            new() { Title = "Impersonation", Controller = "SupportImpersonation", Action = "Index" },
            new() { Title = "Subscription Plans", Controller = "PlatformSubscriptionTiers", Action = "Index" },
            new() { Title = "Billing & Invoices", Controller = "Invoices", Action = "Index" },
            new() { Title = "Support Tickets", Controller = "SupportTickets", Action = "Index" },
            new() { Title = "Support Access", Controller = "SupportAccess", Action = "Index" }
        }.Select(x =>
        {
            x.Slug = operationalSlug;
            return x;
        }));
    }
}

<div class="app-shell">
    <partial name="_SidebarNavigation" model="sidebarItems" />

    <div class="app-main">
        <header class="app-topbar">
            <div class="app-topbar-brand">
                <a class="navbar-brand fw-semibold" asp-area="" asp-controller="Landing" asp-action="Index">@AppNameService.AppName</a>
            </div>
            <div class="app-topbar-actions">
                <ul class="navbar-nav">
                    <partial name="_LoginPartial" />
                </ul>
            </div>
        </header>

        <main id="main-content" role="main" class="app-content">
            @RenderBody()
        </main>
    </div>
</div>

<footer class="border-top footer text-muted py-3 mt-auto">
    <div class="container">
        @AppNameService.AppName - <a asp-area="" asp-controller="Home" asp-action="Privacy">@App.Resources.Views.Shared._Layout.Privacy</a> | 
        <a href="/swagger">Api</a>
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/lib/htmx.org/dist/htmx.min.js"></script>
<script src="~/lib/alpinejs/dist/cdn.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
