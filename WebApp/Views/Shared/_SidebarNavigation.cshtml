@using WebApp.ViewModels.Shared
@model IReadOnlyCollection<AppShellNavigationViewModel>

<aside class="app-sidebar" aria-label="Primary navigation">
    <nav class="app-sidebar-nav">
        <ul class="nav flex-column gap-1">
            @foreach (var item in Model)
            {
                var itemHref = Url.Action(item.Action, item.Controller, new { slug = item.Slug, context = item.Context });
                <li class="nav-item">
                    <a class="nav-link" href="@(itemHref ?? "#")" data-debug-href="@itemHref">@item.Title</a>
                </li>
            }
        </ul>
    </nav>
</aside>
