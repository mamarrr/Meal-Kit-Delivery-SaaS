@model WebApp.ViewModels.Shared.TableShellViewModel

<div class="table-responsive workflow-table-shell">
    <table class="table align-middle">
        <caption class="text-muted">@Model.Caption</caption>
        <thead>
        <tr>
            @foreach (var title in Model.ColumnTitles)
            {
                <th scope="col">@title</th>
            }
        </tr>
        </thead>
        <tbody>
            <tr>
                <td colspan="@Math.Max(Model.ColumnTitles.Length, 1)" class="text-muted">Rows are rendered by the consuming view.</td>
            </tr>
        </tbody>
    </table>
</div>
