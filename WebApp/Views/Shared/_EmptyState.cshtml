@model WebApp.ViewModels.Shared.EmptyStateViewModel

<section class="empty-state border rounded-3 p-4 text-center" aria-live="polite">
    <h2 class="h5 mb-2">@Model.Title</h2>
    <p class="text-muted mb-3">@Model.Message</p>
    @if (!string.IsNullOrWhiteSpace(Model.ActionText) && !string.IsNullOrWhiteSpace(Model.ActionUrl))
    {
        <a class="btn btn-outline-primary" href="@Model.ActionUrl">@Model.ActionText</a>
    }
</section>
