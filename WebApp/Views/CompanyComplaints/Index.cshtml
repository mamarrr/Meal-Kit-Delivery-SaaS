@model WebApp.ViewModels.Delivery.CompanyComplaintsIndexViewModel
@{
    ViewData["Title"] = "Company Complaints";
}

<section class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
        <h1 class="h4 mb-2">Company Complaints</h1>
        <p class="text-muted mb-0">Review customer complaints within the active company scope.</p>
    </div>
</section>

@if (Model.Complaints.Count == 0)
{
    <div class="alert alert-info" role="alert">
        No complaints found for this company.
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                    <tr>
                        <th>Created</th>
                        <th>Customer</th>
                        <th>Delivery</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th>Severity</th>
                        <th class="text-end">Details</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var complaint in Model.Complaints)
                    {
                        <tr>
                            <td>@complaint.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@complaint.CustomerName</td>
                            <td>@complaint.DeliveryReference</td>
                            <td>@complaint.TypeLabel</td>
                            <td>@complaint.StatusLabel</td>
                            <td>@complaint.Severity</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary"
                                   asp-controller="CompanyComplaints"
                                   asp-action="Details"
                                   asp-route-slug="@Model.CompanySlug"
                                   asp-route-id="@complaint.ComplaintId">View</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
