@model WebApp.ViewModels.Delivery.CompanyComplaintDetailsViewModel
@{
    ViewData["Title"] = "Complaint Details";
}

<section class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4 d-flex justify-content-between align-items-center">
        <div>
            <h1 class="h4 mb-1">Complaint @Model.ComplaintId.ToString()[..8]</h1>
            <p class="text-muted mb-0">Detailed complaint information in company scope.</p>
        </div>
        <a class="btn btn-outline-secondary"
           asp-controller="CompanyComplaints"
           asp-action="Index"
           asp-route-slug="@Model.CompanySlug">Back to complaints</a>
    </div>
</section>

<section class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <dl class="row mb-0">
            <dt class="col-sm-3">Created</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>

            <dt class="col-sm-3">Customer</dt>
            <dd class="col-sm-9">@Model.CustomerName</dd>

            <dt class="col-sm-3">Delivery reference</dt>
            <dd class="col-sm-9">@Model.DeliveryReference</dd>

            <dt class="col-sm-3">Type</dt>
            <dd class="col-sm-9">@Model.TypeLabel</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.StatusLabel</dd>

            <dt class="col-sm-3">Severity</dt>
            <dd class="col-sm-9">@Model.Severity</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>

            <dt class="col-sm-3">Updated</dt>
            <dd class="col-sm-9">@(Model.UpdatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</dd>

            <dt class="col-sm-3">Escalated</dt>
            <dd class="col-sm-9">@(Model.EscalatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</dd>

            <dt class="col-sm-3">Escalation action</dt>
            <dd class="col-sm-9">@(Model.EscalationAction ?? "-")</dd>
        </dl>
    </div>
</section>
