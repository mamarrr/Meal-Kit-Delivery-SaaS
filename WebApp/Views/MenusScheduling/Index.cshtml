@model WebApp.ViewModels.Menu.MenusSchedulingIndexViewModel
@{
    ViewData["Title"] = "Menus & Scheduling";
}

<section class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
        <h1 class="h4 mb-2">Menus &amp; Scheduling</h1>
        <p class="text-muted mb-0">Plan weekly menus, configure constraints, and assign recipes.</p>
    </div>
</section>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success" role="alert">@successMessage</div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<section class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
        <form asp-controller="MenusScheduling" asp-action="Index" asp-route-slug="@Model.CompanySlug" method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label" for="weekStartDate">Week</label>
                <input class="form-control" type="date" id="weekStartDate" name="weekStartDate" value="@Model.WeekStartDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-8 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Load week</button>
                <span class="align-self-center text-muted">Week starts Monday.</span>
            </div>
        </form>
    </div>
</section>

<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <section class="card border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <h2 class="h5 mb-3">Menu configuration</h2>
                <form asp-controller="MenusScheduling" asp-action="SaveConfig" asp-route-slug="@Model.CompanySlug" method="post" class="row g-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="WeekStartDate" />
                    <div class="col-md-4">
                        <label class="form-label" asp-for="RuleConfigForm.RecipesPerCategory">Recipes/category</label>
                        <input class="form-control" asp-for="RuleConfigForm.RecipesPerCategory" type="number" min="1" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" asp-for="RuleConfigForm.NoRepeatWeeks">No-repeat weeks</label>
                        <input class="form-control" asp-for="RuleConfigForm.NoRepeatWeeks" type="number" min="0" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" asp-for="RuleConfigForm.SelectionDeadlineDaysBeforeWeekStart">Deadline days before start</label>
                        <input class="form-control" asp-for="RuleConfigForm.SelectionDeadlineDaysBeforeWeekStart" type="number" min="0" />
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-outline-primary">Save configuration</button>
                    </div>
                </form>
            </div>
        </section>
    </div>
    <div class="col-lg-6">
        <section class="card border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <h2 class="h5 mb-3">Recipe assignment</h2>
                <form asp-controller="MenusScheduling" asp-action="AssignRecipe" asp-route-slug="@Model.CompanySlug" method="post" class="row g-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="WeekStartDate" />
                    <div class="col-12">
                        <label class="form-label" asp-for="AssignmentForm.RecipeId">Recipe</label>
                        <select class="form-select" asp-for="AssignmentForm.RecipeId" asp-items="Model.RecipeOptions"></select>
                    </div>
                    <div class="col-12">
                        <p class="text-muted mb-0">Category is assigned automatically from the selected recipe.</p>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary">Assign recipe</button>
                    </div>
                </form>
            </div>
        </section>
    </div>
</div>

<section class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
        <h2 class="h5 mb-3">Weekly assignments</h2>
        @if (Model.Assignments.Count == 0)
        {
            <p class="text-muted mb-0">No assignments yet for this week.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                    <tr>
                        <th>#</th>
                        <th>Recipe</th>
                        <th>Category</th>
                        <th></th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Assignments)
                    {
                        <tr>
                            <td>@(item.DisplayOrder ?? 0)</td>
                            <td>@item.RecipeName</td>
                            <td>@item.DietaryCategoryName</td>
                            <td class="text-end">
                                <form asp-controller="MenusScheduling" asp-action="RemoveAssignment" asp-route-slug="@Model.CompanySlug" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="weeklyMenuRecipeId" value="@item.WeeklyMenuRecipeId" />
                                    <input type="hidden" name="weekStartDate" value="@Model.WeekStartDate.ToString("yyyy-MM-dd")" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>

