@model WebApp.ViewModels.MealPlans.MealPlanDiscoveryViewModel

@{
    ViewData["Title"] = "Discover Meal Plans";
}

<h1>Discover meal-kit plans</h1>
<p class="text-muted">Choose an active plan and continue to subscription setup. (@Model.Plans.Count plan(s) available)</p>

@if (!Model.Plans.Any())
{
    <div class="alert alert-info" role="status">
        No plans are currently available for your company.
        <a class="alert-link" asp-controller="MealSubscriptions" asp-action="Index">Go to subscriptions</a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 g-3">
        @foreach (var plan in Model.Plans)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">@plan.BoxDisplayName</h5>
                        <p class="card-text text-muted mb-2">@plan.MealsCount meals · @plan.PeopleCount people</p>
                        <p class="h5 mb-2">@plan.PriceAmount.ToString("0.00") €</p>
                        <p class="small text-muted mb-3">
                            @if (plan.ValidFrom.HasValue)
                            {
                                <span>Valid from @plan.ValidFrom.Value.ToString("yyyy-MM-dd")</span>
                            }
                            @if (plan.ValidTo.HasValue)
                            {
                                <span> · Valid to @plan.ValidTo.Value.ToString("yyyy-MM-dd")</span>
                            }
                        </p>
                        <a class="btn btn-primary" href="@plan.SubscribeUrl">Subscribe</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
