@model App.Domain.Menu.MealSelection

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>MealSelection</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="SelectedAutomatically" /> @Html.DisplayNameFor(model => model.SelectedAutomatically)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="SelectedAt" class="control-label"></label>
                <input asp-for="SelectedAt" class="form-control" />
                <span asp-validation-for="SelectedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="LockedAt" class="control-label"></label>
                <input asp-for="LockedAt" class="form-control" />
                <span asp-validation-for="LockedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CreatedAt" class="control-label"></label>
                <input asp-for="CreatedAt" class="form-control" />
                <span asp-validation-for="CreatedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="UpdatedAt" class="control-label"></label>
                <input asp-for="UpdatedAt" class="form-control" />
                <span asp-validation-for="UpdatedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DeletedAt" class="control-label"></label>
                <input asp-for="DeletedAt" class="form-control" />
                <span asp-validation-for="DeletedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MealSubscriptionId" class="control-label"></label>
                <select asp-for="MealSubscriptionId" class ="form-control" asp-items="ViewBag.MealSubscriptionId"></select>
            </div>
            <div class="form-group">
                <label asp-for="WeeklyMenuId" class="control-label"></label>
                <select asp-for="WeeklyMenuId" class ="form-control" asp-items="ViewBag.WeeklyMenuId"></select>
            </div>
            <div class="form-group">
                <label asp-for="RecipeId" class="control-label"></label>
                <select asp-for="RecipeId" class ="form-control" asp-items="ViewBag.RecipeId"></select>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

