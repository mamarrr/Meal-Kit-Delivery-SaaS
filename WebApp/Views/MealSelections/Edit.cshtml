@model WebApp.ViewModels.MealSelections.MealSelectionEditViewModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Meal selection</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="MealSelection.SelectedAutomatically" /> @Html.DisplayNameFor(model => model.MealSelection.SelectedAutomatically)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="MealSelection.SelectedAt" class="control-label"></label>
                <input asp-for="MealSelection.SelectedAt" class="form-control" />
                <span asp-validation-for="MealSelection.SelectedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MealSelection.LockedAt" class="control-label"></label>
                <input asp-for="MealSelection.LockedAt" class="form-control" />
                <span asp-validation-for="MealSelection.LockedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MealSelection.CreatedAt" class="control-label"></label>
                <input asp-for="MealSelection.CreatedAt" class="form-control" />
                <span asp-validation-for="MealSelection.CreatedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MealSelection.UpdatedAt" class="control-label"></label>
                <input asp-for="MealSelection.UpdatedAt" class="form-control" />
                <span asp-validation-for="MealSelection.UpdatedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MealSelection.DeletedAt" class="control-label"></label>
                <input asp-for="MealSelection.DeletedAt" class="form-control" />
                <span asp-validation-for="MealSelection.DeletedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MealSelection.MealSubscriptionId" class="control-label"></label>
                <select asp-for="MealSelection.MealSubscriptionId" class="form-control" asp-items="Model.MealSubscriptionOptions"></select>
                <span asp-validation-for="MealSelection.MealSubscriptionId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MealSelection.WeeklyMenuId" class="control-label"></label>
                <select asp-for="MealSelection.WeeklyMenuId" class="form-control" asp-items="Model.WeeklyMenuOptions"></select>
                <span asp-validation-for="MealSelection.WeeklyMenuId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MealSelection.RecipeId" class="control-label"></label>
                <select asp-for="MealSelection.RecipeId" class="form-control" asp-items="Model.RecipeOptions"></select>
                <span asp-validation-for="MealSelection.RecipeId" class="text-danger"></span>
            </div>
            <input type="hidden" asp-for="MealSelection.Id" />
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

