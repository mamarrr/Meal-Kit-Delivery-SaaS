@model IEnumerable<App.Domain.Menu.MealSelection>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.SelectedAutomatically)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SelectedAt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LockedAt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CreatedAt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UpdatedAt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DeletedAt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MealSubscription)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.WeeklyMenu)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Recipe)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.SelectedAutomatically)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.SelectedAt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LockedAt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CreatedAt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UpdatedAt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DeletedAt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MealSubscription!.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.WeeklyMenu!.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Recipe!.Name)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>

