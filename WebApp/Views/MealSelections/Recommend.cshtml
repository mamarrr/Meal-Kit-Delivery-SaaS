@model WebApp.ViewModels.MealSelections.MealSelectionRecommendationViewModel

@{
    ViewData["Title"] = "Auto-selection fallback";
}

<h1>Auto-selection fallback</h1>

<p class="text-muted">Preview fallback recommendations with non-repetition and nutrition filters.</p>

<hr />

<div class="row">
    <div class="col-md-7">
        <form asp-action="Recommend" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="MealSubscriptionId" class="form-label"></label>
                <select asp-for="MealSubscriptionId" asp-items="Model.MealSubscriptionOptions" class="form-select"></select>
                <span asp-validation-for="MealSubscriptionId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="WeeklyMenuId" class="form-label"></label>
                <select asp-for="WeeklyMenuId" asp-items="Model.WeeklyMenuOptions" class="form-select"></select>
                <span asp-validation-for="WeeklyMenuId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="LockedAt" class="form-label"></label>
                <input asp-for="LockedAt" class="form-control" />
                <span asp-validation-for="LockedAt" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="MaxCaloriesKcal" class="form-label"></label>
                    <input asp-for="MaxCaloriesKcal" class="form-control" />
                    <span asp-validation-for="MaxCaloriesKcal" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="MinProteinG" class="form-label"></label>
                    <input asp-for="MinProteinG" class="form-control" />
                    <span asp-validation-for="MinProteinG" class="text-danger"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Generate fallback recommendation</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Back to selections</a>
        </form>
    </div>

    <div class="col-md-5">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Recommendation result</h5>

                @if (!string.IsNullOrWhiteSpace(Model.RecommendationSummary))
                {
                    <div class="alert alert-info" role="alert">
                        @Model.RecommendationSummary
                    </div>
                }
                else
                {
                    <p class="text-muted">Run the form to calculate a fallback recommendation.</p>
                }

                <div class="mb-3">
                    <label asp-for="RecommendedRecipeId" class="form-label"></label>
                    <select asp-for="RecommendedRecipeId" asp-items="Model.RecommendedRecipeOptions" class="form-select" disabled></select>
                </div>

                @if (Model.DecisionNotes.Any())
                {
                    <h6>Decision notes</h6>
                    <ul class="mb-0">
                        @foreach (var note in Model.DecisionNotes)
                        {
                            <li>@note</li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}

