@model WebApp.ViewModels.CompanySettings.CompanyProfileEditViewModel

@{
    ViewData["Title"] = "Company Profile";
}

<h1>Company Profile</h1>
<p class="text-muted">Manage tenant-specific company identity and contact details.</p>

<div class="row">
    <div class="col-lg-8">
        <form asp-action="Profile" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Company.Id" />

            <div class="mb-3">
                <label asp-for="Company.Name" class="form-label"></label>
                <input asp-for="Company.Name" class="form-control" />
                <span asp-validation-for="Company.Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Company.Slug" class="form-label"></label>
                <input asp-for="Company.Slug" class="form-control" />
                <span asp-validation-for="Company.Slug" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Company.RegistrationNumber" class="form-label"></label>
                <input asp-for="Company.RegistrationNumber" class="form-control" />
                <span asp-validation-for="Company.RegistrationNumber" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Company.ContactEmail" class="form-label"></label>
                <input asp-for="Company.ContactEmail" class="form-control" />
                <span asp-validation-for="Company.ContactEmail" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Company.ContactPhone" class="form-label"></label>
                <input asp-for="Company.ContactPhone" class="form-control" />
                <span asp-validation-for="Company.ContactPhone" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Company.WebSiteUrl" class="form-label"></label>
                <input asp-for="Company.WebSiteUrl" class="form-control" />
                <span asp-validation-for="Company.WebSiteUrl" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Save profile</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Company settings</a>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
