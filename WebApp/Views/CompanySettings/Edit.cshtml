@model WebApp.ViewModels.CompanySettings.CompanySettingsEditViewModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>CompanySettings</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="CompanySettings.DefaultNoRepeatWeeks" class="control-label"></label>
                <input asp-for="CompanySettings.DefaultNoRepeatWeeks" class="form-control" />
                <span asp-validation-for="CompanySettings.DefaultNoRepeatWeeks" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CompanySettings.SelectionDeadlineDaysBeforeDelivery" class="control-label"></label>
                <input asp-for="CompanySettings.SelectionDeadlineDaysBeforeDelivery" class="form-control" />
                <span asp-validation-for="CompanySettings.SelectionDeadlineDaysBeforeDelivery" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="CompanySettings.AllowAutoSelection" /> @Html.DisplayNameFor(model => model.CompanySettings.AllowAutoSelection)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="CompanySettings.AllowPauseSubscription" /> @Html.DisplayNameFor(model => model.CompanySettings.AllowPauseSubscription)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="CompanySettings.AllowSkipWeek" /> @Html.DisplayNameFor(model => model.CompanySettings.AllowSkipWeek)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="CompanySettings.MinimumSubscriptionWeeks" class="control-label"></label>
                <input asp-for="CompanySettings.MinimumSubscriptionWeeks" class="form-control" />
                <span asp-validation-for="CompanySettings.MinimumSubscriptionWeeks" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CompanySettings.MaxDeliveryAttempts" class="control-label"></label>
                <input asp-for="CompanySettings.MaxDeliveryAttempts" class="form-control" />
                <span asp-validation-for="CompanySettings.MaxDeliveryAttempts" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="CompanySettings.AllowRedeliveryAfterFailure" /> @Html.DisplayNameFor(model => model.CompanySettings.AllowRedeliveryAfterFailure)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="CompanySettings.ComplaintEscalationThreshold" class="control-label"></label>
                <input asp-for="CompanySettings.ComplaintEscalationThreshold" class="form-control" />
                <span asp-validation-for="CompanySettings.ComplaintEscalationThreshold" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CompanySettings.ComplaintEscalationDaysWindow" class="control-label"></label>
                <input asp-for="CompanySettings.ComplaintEscalationDaysWindow" class="form-control" />
                <span asp-validation-for="CompanySettings.ComplaintEscalationDaysWindow" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="CompanySettings.AutoPrioritizeFreshestStock" /> @Html.DisplayNameFor(model => model.CompanySettings.AutoPrioritizeFreshestStock)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="CompanySettings.AutoAssignEarliestSlot" /> @Html.DisplayNameFor(model => model.CompanySettings.AutoAssignEarliestSlot)
                </label>
            </div>
            <input type="hidden" asp-for="CompanySettings.Id" />
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

