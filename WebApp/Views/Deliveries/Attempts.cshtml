@model IEnumerable<App.Domain.Delivery.DeliveryAttempt>
@using App.Domain.Delivery

@{
    ViewData["Title"] = "Delivery Attempts";
    var delivery = ViewBag.Delivery as Delivery;
}

<h1>Delivery Attempts</h1>

<div class="mb-3">
    <h4>Delivery: @delivery?.Id.ToString()[..8]...</h4>
    <p>Scheduled: @delivery?.ScheduledTime.ToString("yyyy-MM-dd HH:mm")</p>
    <p>Status: @delivery?.DeliveryStatus?.Label</p>
</div>

<p>
    <a asp-action="Details" asp-route-id="@delivery?.Id" class="btn btn-secondary">Back to Delivery</a>
    <a asp-controller="DeliveryAttempts" asp-action="Create" class="btn btn-primary">Record New Attempt</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Attempt #</th>
            <th>Attempt Time</th>
            <th>Result</th>
            <th>Notes</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.AttemptNo</td>
                    <td>@item.AttemptAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        <span class="badge @(item.DeliveryAttemptResult?.Code == "SUCCESS" ? "bg-success" : "bg-warning")">
                            @item.DeliveryAttemptResult?.Label
                        </span>
                    </td>
                    <td>@item.Notes</td>
                    <td>
                        <a asp-controller="DeliveryAttempts" asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                        <a asp-controller="DeliveryAttempts" asp-action="Details" asp-route-id="@item.Id">Details</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center text-muted">No delivery attempts recorded yet.</td>
            </tr>
        }
    </tbody>
</table>
