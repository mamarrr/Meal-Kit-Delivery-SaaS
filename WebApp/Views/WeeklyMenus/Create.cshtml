@model App.Domain.Menu.WeeklyMenu

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>WeeklyMenu</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="WeekStartDate" class="control-label"></label>
                <input asp-for="WeekStartDate" class="form-control" />
                <span asp-validation-for="WeekStartDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="SelectionDeadlineAt" class="control-label"></label>
                <input asp-for="SelectionDeadlineAt" class="form-control" />
                <span asp-validation-for="SelectionDeadlineAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TotalRecipes" class="control-label"></label>
                <input asp-for="TotalRecipes" class="form-control" />
                <span asp-validation-for="TotalRecipes" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="IsPublished" /> @Html.DisplayNameFor(model => model.IsPublished)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="PublishedAt" class="control-label"></label>
                <input asp-for="PublishedAt" class="form-control" />
                <span asp-validation-for="PublishedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CreatedAt" class="control-label"></label>
                <input asp-for="CreatedAt" class="form-control" />
                <span asp-validation-for="CreatedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="UpdatedAt" class="control-label"></label>
                <input asp-for="UpdatedAt" class="form-control" />
                <span asp-validation-for="UpdatedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DeletedAt" class="control-label"></label>
                <input asp-for="DeletedAt" class="form-control" />
                <span asp-validation-for="DeletedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CompanyId" class="control-label"></label>
                <select asp-for="CompanyId" class ="form-control" asp-items="ViewBag.CompanyId"></select>
            </div>
            <div class="form-group">
                <label asp-for="CreatedByAppUserId" class="control-label"></label>
                <select asp-for="CreatedByAppUserId" class ="form-control" asp-items="ViewBag.CreatedByAppUserId"></select>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

