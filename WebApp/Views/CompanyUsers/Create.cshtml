@model WebApp.ViewModels.CompanyUsers.CompanyUserEditViewModel

@{
    ViewData["Title"] = "Add user";
}

<h1>Add user to company</h1>
<p class="text-muted">Enter an existing account email and assign a role.</p>

<div class="row">
    <div class="col-lg-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="TargetEmail" class="form-label">User email</label>
                <input asp-for="TargetEmail" class="form-control" autocomplete="email" />
                <span asp-validation-for="TargetEmail" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CompanyAppUser.CompanyRoleId" class="form-label">Role</label>
                <select asp-for="CompanyAppUser.CompanyRoleId" class="form-select" asp-items="Model.CompanyRoleOptions"></select>
                <span asp-validation-for="CompanyAppUser.CompanyRoleId" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Add user</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
