@model WebApp.ViewModels.Boxes.BoxEditViewModel

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Box</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Box.MealsCount" class="control-label"></label>
                <input asp-for="Box.MealsCount" class="form-control" />
                <span asp-validation-for="Box.MealsCount" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Box.PeopleCount" class="control-label"></label>
                <input asp-for="Box.PeopleCount" class="form-control" />
                <span asp-validation-for="Box.PeopleCount" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Box.DisplayName" class="control-label"></label>
                <input asp-for="Box.DisplayName" class="form-control" />
                <span asp-validation-for="Box.DisplayName" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Box.IsActive" /> @Html.DisplayNameFor(model => model.Box.IsActive)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

