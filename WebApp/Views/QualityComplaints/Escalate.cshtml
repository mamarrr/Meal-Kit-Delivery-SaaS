@model App.Domain.Delivery.QualityComplaint

@{
    ViewData["Title"] = "Escalate Complaint";
}

<h1>Escalate Quality Complaint</h1>

<div class="alert alert-warning">
    <h4>Escalation Action Required</h4>
    <p>You are about to escalate this quality complaint. This will be recorded and may trigger additional workflows.</p>
</div>

<div>
    <h4>Complaint Details</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Severity)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Severity)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class="col-sm-2">
            Customer
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Customer!.FirstName) @Html.DisplayFor(model => model.Customer!.LastName)
        </dd>
        <dt class="col-sm-2">
            Current Status
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.QualityComplaintStatus!.Label)
        </dd>
    </dl>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Escalate">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-group mb-3">
                <label for="escalationAction" class="control-label">Escalation Action</label>
                <textarea name="escalationAction" id="escalationAction" class="form-control" rows="4" 
                    placeholder="Describe the escalation action being taken..." required></textarea>
                <span class="text-danger">@Html.ValidationMessage("escalationAction")</span>
            </div>
            
            <div class="form-group">
                <input type="submit" value="Escalate Complaint" class="btn btn-warning" />
                <a asp-action="Details" asp-route-id="@Model?.Id" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
